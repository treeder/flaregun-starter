{
  "name": "flaregun-starter",
  "type": "module",
  "version": "2.0.0",
  "main": "index.js",
  "scripts": {
    "start": "vite --port 8787",
    "build": "vite build",
    "run": "vite --port 8787",
    "test:run": "node tests/tests.js",
    "test": "npx -y treeder/testkit --port=8787",
    "setup": "npx -y treeder/flaregun setup",
    "deploy": "npm run build && wrangler deploy",
    "deploy:preview": "npm run build && wrangler versions upload",
    "deploy:dev": "npm run build && wrangler deploy --env dev",
    "deploy:prod": "npm run build && wrangler deploy --env prod",
    "deploy:prod:preview": "npm run build && wrangler versions upload --env prod",
    "pushdev": "git push origin --force `git symbolic-ref --short HEAD`:dev"
  },
  "author": "treeder",
  "license": "Apache-2.0",
  "description": "",
  "dependencies": {
    "api": "github:treeder/api#semver:^1",
    "console-logger": "github:treeder/console-logger#semver:^1",
    "flaregun": "github:treeder/flaregun#semver:^4",
    "migrations": "github:treeder/migrations#semver:^1",
    "nanoid": "^5.1.5",
    "once": "github:treeder/once#semver:^1",
    "passkeys": "github:treeder/passkeys#semver:^3",
    "rend": "github:treeder/rend#semver:^1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "cross-env": "^7.0.3",
    "prettier": "^3.6.2",
    "testkit": "github:treeder/testkit#semver:^2",
    "vite": "^8.1.0",
    "wrangler": "^4.105.0"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "all",
    "printWidth": 120,
    "bracketSameLine": true
  }
}
